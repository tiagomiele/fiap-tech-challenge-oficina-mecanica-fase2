digraph processo {
  rankdir=LR;
  bgcolor="white";
  labelloc="t";
  fontname="Helvetica-Bold";
  fontsize=22;
  label="Oficina Mecanica - Visao de PROCESSO (Value Stream de Entrega Fim a Fim)";
  nodesep=0.5;
  ranksep=0.9;
  compound=true;

  node [fontname="Helvetica", fontsize=12, style="filled,rounded", shape=box, color="#37474F", penwidth=1.2];
  edge [fontname="Helvetica", fontsize=11, color="#37474F", penwidth=1.4];

  // ===== Fase 1 - Desenvolvimento =====
  subgraph cluster_dev {
    label="1 - DESENVOLVIMENTO"; style="filled,rounded"; color="#BBDEFB"; fontsize=15; fontname="Helvetica-Bold";
    d1 [label="Codificar feature\n(Clean Architecture + SOLID)", fillcolor="#E3F2FD"];
    d2 [label="Testes locais\n(./mvnw verify)", fillcolor="#E3F2FD"];
    d3 [label="Abrir Pull Request\nno GitHub", fillcolor="#E3F2FD"];
    d1 -> d2 -> d3;
  }

  // ===== Fase 2 - CI =====
  subgraph cluster_ci {
    label="2 - INTEGRACAO CONTINUA (ci.yml)"; style="filled,rounded"; color="#C8E6C9"; fontsize=15; fontname="Helvetica-Bold";
    c1 [label="Build + Testes\nMaven / JUnit", fillcolor="#E8F5E9"];
    g1 [label="Cobertura >= 80% (JaCoCo)\n+ ArchUnit OK?", shape=diamond, fillcolor="#FFF9C4", color="#F9A825"];
    c2 [label="Seguranca:\nTrivy + SBOM CycloneDX\n-> Dependency-Track", fillcolor="#E8F5E9"];
    c1 -> g1;
    g1 -> c2 [label="sim"];
  }

  // ===== Fase 3 - CD (build/imagem) =====
  subgraph cluster_cd {
    label="3 - ENTREGA CONTINUA (cd.yml)"; style="filled,rounded"; color="#D1C4E9"; fontsize=15; fontname="Helvetica-Bold";
    cd1 [label="Build imagem Docker", fillcolor="#EDE7F6"];
    cd2 [label="Publicar no registry\nGHCR (ghcr.io)", fillcolor="#EDE7F6"];
    cd1 -> cd2;
  }

  // ===== Fase 4 - IaC =====
  subgraph cluster_iac {
    label="4 - PROVISIONAMENTO / IaC (infra.yml)"; style="filled,rounded"; color="#FFE0B2"; fontsize=15; fontname="Helvetica-Bold";
    i1 [label="Terraform @ Terraform Cloud\nplan + apply", fillcolor="#FFF3E0"];
    i2 [label="AWS provisionada\nVPC + EKS + RDS + rede", fillcolor="#FFF3E0"];
    i1 -> i2;
  }

  // ===== Fase 5 - Deploy por ambiente =====
  subgraph cluster_deploy {
    label="5 - DEPLOY POR AMBIENTE (deploy.yml)"; style="filled,rounded"; color="#B2DFDB"; fontsize=15; fontname="Helvetica-Bold";
    p1 [label="Deploy STG\nkubectl apply + rollout", fillcolor="#E0F2F1"];
    p2 [label="Deploy Pre-producao\n+ smoke test /actuator/health", fillcolor="#E0F2F1"];
    g2 [label="Aprovacao manual\n(producao)?", shape=diamond, fillcolor="#FFF9C4", color="#F9A825"];
    p3 [label="Deploy PRODUCAO", fillcolor="#E0F2F1"];
    p1 -> p2 -> g2;
    g2 -> p3 [label="aprovado"];
  }

  // ===== Fase 6 - Operacao =====
  subgraph cluster_ops {
    label="6 - OPERACAO / RUNTIME"; style="filled,rounded"; color="#F8BBD0"; fontsize=15; fontname="Helvetica-Bold";
    o1 [label="Usuarios usam a API\n(ELB -> pods Spring Boot)", fillcolor="#FCE4EC"];
    o2 [label="App -> RDS (JPA/Flyway)\nApp -> Mailtrap (SMTP)", fillcolor="#FCE4EC"];
    o3 [label="HPA escala pods\n(CPU/memoria)", fillcolor="#FCE4EC"];
    o1 -> o2; o1 -> o3;
  }

  // ===== Ligacoes entre fases =====
  d3 -> c1 [ltail=cluster_dev, lhead=cluster_ci, label="dispara CI", penwidth=2, color="#1565C0"];
  c2 -> cd1 [ltail=cluster_ci, lhead=cluster_cd, label="merge -> main", penwidth=2, color="#2E7D32"];
  cd2 -> p1 [ltail=cluster_cd, lhead=cluster_deploy, label="imagem pronta", penwidth=2, color="#6A1B9A"];
  i2 -> p1 [lhead=cluster_deploy, label="infra pronta", style=dashed, penwidth=2, color="#E65100"];
  p3 -> o1 [ltail=cluster_deploy, lhead=cluster_ops, label="app no ar", penwidth=2, color="#00695C"];

  // ===== Feedback (falhas voltam pro dev) =====
  g1 -> d1 [label="falhou -> corrigir", color="#C62828", style=dashed, constraint=false];
  g2 -> d1 [label="reprovado", color="#C62828", style=dashed, constraint=false];
}
