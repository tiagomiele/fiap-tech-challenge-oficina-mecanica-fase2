@startuml oficina-c4-nivel2
!include c4inc/C4_Container.puml

LAYOUT_WITH_LEGEND()
title Diagrama C4 - Nivel 2 (Container) - Sistema de Gestao da Oficina Mecanica

Person(cliente, "Cliente", "Consulta status e aprova/reprova orcamento (rotas publicas).")
Person(admin, "Perfil 02 - Administrativo", "Gerencia OS, cadastros, estoque, financeiro e relatorios.")
Person(tecnico, "Perfil 03 - Tecnico", "Diagnostico, orcamento e execucao do reparo.")

System_Boundary(eks, "Cluster Kubernetes / Amazon EKS  (namespace: oficina)") {
    Container(api, "API REST - oficina-backend", "Java 21 / Spring Boot 3", "Aplicacao monolitica em Clean Architecture (4 aneis). Frameworks: Spring Web (REST), Spring Security + JWT, Spring Data JPA/Hibernate, Flyway (migracoes), Spring Mail (SMTP), SpringDoc/OpenAPI (Swagger). Deployment com 2+ replicas, probes readiness/liveness.")
    Container(svc, "Service + HPA", "Kubernetes Service (LoadBalancer) + HorizontalPodAutoscaler", "Expoe a API via ELB e escala as replicas por consumo de CPU/memoria.")
    Container(cfg, "ConfigMap + Secret", "Kubernetes ConfigMap / Secret", "Injeta configuracao (perfil, host de e-mail) e dados sensiveis (senha do banco, credenciais SMTP, chave JWT) como variaveis de ambiente na API.")
}

ContainerDb(db, "Banco de Dados", "PostgreSQL (Amazon RDS)", "Persiste OS, orcamentos, clientes, veiculos, estoque, notas fiscais e lancamentos financeiros. Schema versionado por Flyway.")
System_Ext(mail, "Mailtrap (Servidor SMTP)", "Sandbox de e-mail para as notificacoes de mudanca de status.")

Rel(cliente, svc, "Consulta status / aprova / reprova", "HTTPS / REST (publico)")
Rel(admin, svc, "Administra a oficina e as OS", "HTTPS / REST + JWT")
Rel(tecnico, svc, "Diagnostico, orcamento e execucao", "HTTPS / REST + JWT")

Rel(svc, api, "Roteia requisicoes / balanceia", "HTTP interno")
Rel(cfg, api, "Fornece config e segredos", "env vars")
Rel(api, db, "Le e grava dados", "JDBC / JPA (Hibernate) + Flyway")
Rel(api, mail, "Envia e-mail de notificacao", "SMTP (Spring Mail)")
Rel_Back(cliente, api, "Notifica atualizacao de status", "E-mail")

SHOW_LEGEND()
@enduml
